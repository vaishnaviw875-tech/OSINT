    "api/scrape-twitter.js":              { "maxDuration": 300 },
    "api/scrape-linkedin.js":             { "maxDuration": 300 },
    "api/scrape-instagram.js":            { "maxDuration": 300 },
    "api/scrape-instagram-posts.js":      { "maxDuration": 300 },
    "api/scrape-instagram-posts-poll.js": { "maxDuration": 300 },
    "api/scrape-facebook.js":             { "maxDuration": 300 },
    "api/scrape-contacts.js":             { "maxDuration": 300 },
    "api/bitquery-tx.js":                 { "maxDuration": 30  },
    "api/bitquery-token.js":              { "maxDuration": 15  },
    "api/bitquery-wallet.js":             { "maxDuration": 30  },
    "api/epieos-osint.js":                { "maxDuration": 120 }
  }
}
