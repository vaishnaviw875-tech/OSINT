# ── Gemini AI (required for AI-powered OSINT analysis) ─────────────────────
# Get your key at: https://aistudio.google.com/apikey
# For LOCAL dev: copy this file to .env and paste your key here
# For VERCEL/NETLIFY: add VITE_GEMINI_API_KEY in project Environment Variables
VITE_GEMINI_API_KEY=your_gemini_api_key_here
VITE_GEMINI_MODEL=gemini-2.5-flash

# ── Supabase (database — stores investigations) ─────────────────────────────
# Get these at: https://supabase.com/dashboard/project/_/settings/api
# For LOCAL dev: copy this file to .env and paste your values here
# For VERCEL/NETLIFY: add these in project Environment Variables
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_public_key_here
